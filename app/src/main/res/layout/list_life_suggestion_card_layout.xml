<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginEnd="10dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?android:attr/selectableItemBackground"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="#FFFFFF"
    android:layout_margin="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="15dp">

        <!-- 图标 + 标题行 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="5dp">

            <FrameLayout
                android:layout_width="36dp"
                android:layout_height="36dp">

                <View
                    android:id="@+id/view_life_icon_bg"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/shape_circle_grey" />

                <TextView
                    android:id="@+id/tv_life_icon"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:gravity="center"
                    android:textSize="16sp" />
            </FrameLayout>

            <!-- 展开/收起箭头 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/tv_life_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="测试"
                    android:maxLines="1"
                    android:textColor="#2f3542"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_life_brief"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:background="@drawable/edit_style"
                    android:text="测试"
                    android:layout_marginTop="5dp"
                    android:textColor="#3742fa"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <ImageView
                android:id="@+id/iv_life_arrow"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:background="@drawable/collapse_vertical_line"
                android:visibility="gone"
                android:contentDescription="展开" />
        </LinearLayout>

        <!-- 详情（默认隐藏，点击展开） -->
        <TextView
            android:id="@+id/tv_life_details"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="5dp"
            android:paddingBottom="5dp"
            android:background="@drawable/edit_style"
            android:text="水水水水水水水水水水水水水水水水水水水"
            android:textColor="#57606f"
            android:textSize="11sp"
            android:lineSpacingMultiplier="1.4"
            android:visibility="gone" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>