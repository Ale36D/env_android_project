<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet_round">
    <View
        android:layout_marginTop="16dp"
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:background="#CCCCCC"
        android:layout_marginBottom="16dp"/>
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cb_config_mqtt_card"
        android:layout_margin="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp">
        <LinearLayout
            android:padding="15dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <TextView
                android:layout_marginTop="10dp"
                android:layout_marginBottom="10dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="MQTT 配置"
                android:textStyle="bold"
                android:textColor="#57606f"
                android:textSize="24sp"
                android:gravity="center"/>
            <TextView
                android:layout_marginTop="10dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:background="@drawable/edit_style"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"
                android:text="MQTT 地址"
                android:textColor="#57606f"
                android:textSize="14sp"/>

            <EditText
                android:id="@+id/et_mqtt_broker"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/edit_style"
                android:hint="tcp://IP:Port"
                android:padding="15dp"
                android:textColorHint="#a4b0be"
                android:textSize="14sp" />

            <TextView
                android:layout_marginTop="10dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:background="@drawable/edit_style"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"
                android:text="MQTT 客户端ID"
                android:textColor="#57606f"
                android:textSize="14sp"/>
            <EditText
                android:id="@+id/et_mqtt_client_id"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Client ID"
                android:textColorHint="#a4b0be"
                android:textSize="14sp"
                android:padding="15dp"
                android:background="@drawable/edit_style"/>
            <TextView
                android:layout_marginTop="10dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:background="@drawable/edit_style"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"
                android:text="MQTT 发布者主题"
                android:textColor="#57606f"
                android:textSize="14sp"/>
            <EditText
                android:id="@+id/et_mqtt_publish_topic"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Publish Topic"
                android:textColorHint="#a4b0be"
                android:textSize="14sp"
                android:padding="15dp"
                android:background="@drawable/edit_style"/>
            <TextView
                android:layout_marginTop="10dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:background="@drawable/edit_style"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"
                android:text="MQTT 订阅者主题"
                android:textColor="#57606f"
                android:textSize="14sp"/>
            <EditText
                android:id="@+id/et_mqtt_subscribe_topic"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Subscribe Topic"
                android:textColorHint="#a4b0be"
                android:textSize="14sp"
                android:padding="15dp"
                android:background="@drawable/edit_style"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_set_mqtt_config"
                android:layout_marginTop="15dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="10dp"
                android:text="设置"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:backgroundTint="@color/btn_blue_bg"
                app:cornerRadius="16dp"
                app:elevation="8dp"
                app:pressedTranslationZ="8dp"/>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>


</LinearLayout>